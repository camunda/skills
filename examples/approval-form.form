{
  "components": [
    {
      "text": "### Invoice Review",
      "type": "text",
      "id": "Text_Header",
      "layout": {
        "row": "row_0",
        "columns": null
      }
    },
    {
      "label": "Invoice ID",
      "type": "textfield",
      "id": "Field_InvoiceId",
      "key": "invoiceId",
      "readonly": true,
      "layout": {
        "row": "row_1",
        "columns": null
      }
    },
    {
      "label": "Vendor",
      "type": "textfield",
      "id": "Field_Vendor",
      "key": "vendor",
      "readonly": true,
      "layout": {
        "row": "row_2",
        "columns": null
      }
    },
    {
      "label": "Amount",
      "type": "number",
      "id": "Field_Amount",
      "key": "amount",
      "readonly": true,
      "layout": {
        "row": "row_2",
        "columns": null
      }
    },
    {
      "label": "Description",
      "type": "textarea",
      "id": "Field_Description",
      "key": "description",
      "readonly": true,
      "layout": {
        "row": "row_3",
        "columns": null
      }
    },
    {
      "type": "separator",
      "id": "Separator_1",
      "layout": {
        "row": "row_4",
        "columns": null
      }
    },
    {
      "label": "Approve this invoice?",
      "type": "checkbox",
      "id": "Field_Approved",
      "key": "approved",
      "layout": {
        "row": "row_5",
        "columns": null
      }
    },
    {
      "label": "Comments",
      "type": "textarea",
      "id": "Field_Comments",
      "key": "comments",
      "description": "Required when rejecting",
      "conditional": {
        "hide": "=approved = true"
      },
      "validate": {
        "required": true,
        "requiredErrorMessage": "Please provide a reason for rejection"
      },
      "layout": {
        "row": "row_6",
        "columns": null
      }
    }
  ],
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.8.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.34.0"
  },
  "schemaVersion": 18,
  "id": "approval-form",
  "type": "default"
}
