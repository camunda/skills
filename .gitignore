# Dependencies
node_modules/

# Element templates cache
element-templates/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Claude Code local settings
.claude/settings.local.json

# Bridged skills directory (generated by tools/eval-runner/sdk_runner.py
# so the SDK can discover skills at .claude/skills/<name>/SKILL.md while
# the source-of-truth lives at skills/<name>/).
.claude/skills/

# Transient slash-command files written by skill-creator's run_eval.py
# during a trigger eval and removed in its finally block. Orphaned only
# if the run is hard-killed (SIGKILL skips finally).
.claude/commands/

# Eval workspaces (generated by skill-creator eval runs)
# Note: this is the top-level workspace dir, NOT skills/<name>/evals/ which contains evals.json
/evals/

# Logs
*.log

# Python
__pycache__/
*.py[cod]
.venv/
# uv: tools pin deps via PEP 723 + pyproject; lockfiles are not committed
tools/*/uv.lock

# Pinned external clones (managed by `make setup-skill-creator`)
tools/external/
