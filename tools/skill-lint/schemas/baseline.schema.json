{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://camunda.com/skills/baseline.schema.json",
  "title": "baseline.json",
  "type": "object",
  "required": [
    "schema_version",
    "skill",
    "established_at",
    "established_by",
    "source_iteration",
    "model",
    "trials_per_case",
    "triggers",
    "quality",
    "regression_thresholds"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "skill": { "type": "string", "minLength": 1 },
    "established_at": { "type": "string", "format": "date-time" },
    "established_by": { "type": "string", "minLength": 1 },
    "source_iteration": { "type": "string", "minLength": 1 },
    "model": {
      "type": "object",
      "required": ["provider", "id", "harness", "judge"],
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "harness": { "type": "string", "minLength": 1 },
        "judge": { "type": "string", "minLength": 1 }
      }
    },
    "trials_per_case": { "type": "integer", "minimum": 1 },
    "triggers": {
      "type": "object",
      "required": ["f1", "precision", "recall", "positive_cases", "negative_cases"],
      "additionalProperties": false,
      "properties": {
        "f1": { "type": "number", "minimum": 0, "maximum": 1 },
        "precision": { "type": "number", "minimum": 0, "maximum": 1 },
        "recall": { "type": "number", "minimum": 0, "maximum": 1 },
        "positive_cases": { "type": "integer", "minimum": 0 },
        "negative_cases": { "type": "integer", "minimum": 0 }
      }
    },
    "quality": {
      "type": "object",
      "required": ["with_skill", "without_skill", "delta_pp"],
      "additionalProperties": false,
      "properties": {
        "with_skill": { "$ref": "#/$defs/qualityArm" },
        "without_skill": { "$ref": "#/$defs/qualityArm" },
        "delta_pp": { "type": "number" },
        "per_case": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "with_skill", "without_skill"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "with_skill": { "type": "number", "minimum": 0, "maximum": 1 },
              "without_skill": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        }
      }
    },
    "regression_thresholds": {
      "type": "object",
      "required": ["with_skill_pass_rate_drop_pp", "trigger_f1_drop_pp", "sustained_runs"],
      "additionalProperties": false,
      "properties": {
        "with_skill_pass_rate_drop_pp": { "type": "number", "minimum": 0 },
        "trigger_f1_drop_pp": { "type": "number", "minimum": 0 },
        "sustained_runs": { "type": "integer", "minimum": 1 },
        "noise_floor_pp": { "type": "number", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "qualityArm": {
      "type": "object",
      "required": ["pass_rate", "n_cases", "n_trials"],
      "additionalProperties": false,
      "properties": {
        "pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "n_cases": { "type": "integer", "minimum": 0 },
        "n_trials": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
